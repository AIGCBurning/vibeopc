---
/**
 * Pillars — Bento-style card grid (Lando helmet-grid inspired)
 * - Section label + split-text heading
 * - 3-column grid with hover lift + glow border
 * - SVG icons (not emoji)
 * - Tag pills + "learn more" hover link
 */
const pillars = [
  {
    tag: "Tools",
    accent: "lime",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>`,
    title: "Launchpad",
    desc: "AI workflow templates, curated tool stacks, and battle-tested playbooks. Go from idea to revenue — solo.",
  },
  {
    tag: "Network",
    accent: "purple",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    title: "Community",
    desc: "Build in public with fellow OPCs. Share wins, get roasted, find your tribe of relentless solo builders.",
  },
  {
    tag: "Launch",
    accent: "blue",
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 6 9 6 9z"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C17 4 18 9 18 9z"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>`,
    title: "Showcase",
    desc: "Ship your work, get featured, let the community vote. The best solo-built products rise to the top.",
  },
];
---

<section class="pillars" id="pillars" data-theme="lime">
  <div class="container">
    <div class="section-label reveal" data-anim="fade">
      <span class="section-label__dot"></span>
      <span>Platform</span>
    </div>

    <h2 class="pillars__heading" data-split-text>
      <div class="split-line"><span class="split-word">Everything</span> <span class="split-word">an</span></div>
      <div class="split-line"><span class="split-word pillars__lime">OPC</span> <span class="split-word">needs.</span></div>
    </h2>

    <div class="pillars__grid">
      {pillars.map((p, i) => (
        <article class="pillars__card card" data-anim="clip-up" data-delay={i * 0.12} data-accent={p.accent}>
          <span class="pillars__tag">{p.tag}</span>
          <div class="pillars__icon" set:html={p.icon} />
          <h3 class="pillars__title">{p.title}</h3>
          <p class="pillars__desc">{p.desc}</p>
          <span class="pillars__more">
            Learn more
            <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
.pillars {
  padding: var(--section-pad) 0;

  &__heading {
    font-size: var(--fs-h1);
    margin-bottom: clamp(48px, 6vw, 88px);
  }
  &__lime { color: var(--c-lime); }

  &__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(14px, 1.5vw, 22px);
    @media (max-width: 1024px) { grid-template-columns: repeat(2, 1fr); }
    @media (max-width: 640px) { grid-template-columns: 1fr; }
  }

  &__card {
    padding: clamp(28px, 3vw, 44px);
    display: flex;
    flex-direction: column;
    gap: 14px;
    cursor: default;
  }

  &__tag {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 600;
    font-size: var(--fs-tag);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-lime);
    background: rgba(210,255,0,0.07);
    padding: 5px 14px;
    border-radius: 100px;
    align-self: flex-start;
  }

  &__icon {
    color: var(--c-lime);
    margin: 8px 0 4px;
    opacity: 0.85;
    transition: opacity 0.4s var(--cubic);
  }

  &__title {
    font-size: var(--fs-h3);
    line-height: 1.1;
    letter-spacing: -0.025em;
  }

  &__desc {
    color: var(--c-grey-1);
    font-size: var(--fs-body);
    line-height: 1.7;
    flex: 1;
  }

  &__more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: 'Inter Tight', sans-serif;
    font-weight: 600;
    font-size: var(--fs-small);
    color: var(--c-grey-2);
    margin-top: 8px;
    transition: color 0.4s var(--cubic), gap 0.4s var(--cubic);

    svg { transition: transform 0.4s var(--cubic); }
  }

  &__card:hover {
    .pillars__icon { opacity: 1; }
    .pillars__more {
      color: var(--c-lime);
      gap: 10px;
      svg { transform: translateX(2px); }
    }
  }

  // Accent color variants
  &__card[data-accent="lime"] {
    .pillars__icon { color: var(--c-lime); }
    .pillars__tag { color: var(--c-lime); background: rgba(210,255,0,0.07); }
    &:hover {
      border-color: rgba(210,255,0,0.25);
      .pillars__more { color: var(--c-lime); }
    }
  }
  &__card[data-accent="purple"] {
    .pillars__icon { color: var(--c-purple); }
    .pillars__tag { color: var(--c-purple); background: rgba(202,69,123,0.1); }
    &:hover {
      border-color: rgba(202,69,123,0.3);
      .pillars__more { color: var(--c-purple); }
    }
  }
  &__card[data-accent="blue"] {
    .pillars__icon { color: var(--c-blue); }
    .pillars__tag { color: var(--c-blue); background: rgba(159,161,223,0.1); }
    &:hover {
      border-color: rgba(159,161,223,0.3);
      .pillars__more { color: var(--c-blue); }
    }
  }
}
</style>
