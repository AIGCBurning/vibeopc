---
/**
 * Vision3D — Three.js 3D brand element
 * - TorusKnot with noise displacement + lime wireframe + bloom
 * - Mouse rotation + scroll deformation
 * - Placed between Manifesto and Showcase
 */
---

<section class="vision3d" id="vision3d">
  <div class="vision3d__canvas-wrap" data-vision3d-reveal>
    <canvas id="vision3d-canvas" class="vision3d__canvas" aria-hidden="true"></canvas>
  </div>
  <div class="vision3d__content container">
    <div class="section-label" data-anim="clip-left">
      <span class="section-label__dot"></span>
      <span>Vision</span>
    </div>
    <h2 class="vision3d__heading" data-split-text>
      <div class="split-line"><span class="split-word">Where</span> <span class="split-word">one</span></div>
      <div class="split-line"><span class="split-word">becomes</span> <span class="split-word vision3d__lime">infinite.</span></div>
    </h2>
  </div>
</section>

<style lang="scss">
.vision3d {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  overflow: hidden;

  &__canvas-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0;
    transform: scale(0.92);
    will-change: transform, opacity;
  }

  &__canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  &__content {
    position: relative;
    z-index: 1;
    padding: var(--section-pad) 0;
  }

  &__heading {
    font-size: var(--fs-h1);
    max-width: 700px;
  }

  &__lime { color: var(--c-lime); }
}
</style>
