---
/**
 * Hero — Full-viewport hero (Lando Norris replica)
 * - Grid background + dual gradient orbs
 * - Massive display type with split-text line reveal
 * - Tag line with dividers
 * - Dual CTA buttons
 * - Animated scroll indicator
 */
---

<section class="hero" id="hero">
  <!-- Layers -->
  <canvas id="hero-shader" class="hero__shader" aria-hidden="true"></canvas>
  <canvas id="hero-particles" class="hero__canvas" aria-hidden="true"></canvas>
  <div class="grid-bg" aria-hidden="true"></div>
  <div class="orb orb--lime hero__orb-1" aria-hidden="true"></div>
  <div class="orb orb--purple hero__orb-2" aria-hidden="true"></div>

  <div class="hero__content container">
    <!-- Overline tags -->
    <div class="hero__tags reveal" data-anim="fade">
      <span class="hero__tag">AI-Powered</span>
      <span class="hero__tag-sep">/</span>
      <span class="hero__tag">One-Person Company</span>
      <span class="hero__tag-sep">/</span>
      <span class="hero__tag">Build Solo</span>
    </div>

    <!-- Display title (split-text reveal) -->
    <h1 class="hero__title" data-split-text>
      <div class="split-line"><span class="split-word">Build</span> <span class="split-word">Your</span></div>
      <div class="split-line"><span class="split-word hero__lime">Empire.</span></div>
    </h1>

    <!-- Sub-headline -->
    <p class="hero__sub reveal" data-anim="fade">
      One person. AI-powered. Infinite leverage.<br/>
      The home base for solo builders who refuse to think small.
    </p>

    <!-- CTA group -->
    <div class="hero__ctas reveal" data-anim="fade">
      <a href="#cta" class="btn-primary">
        <span class="btn-text"><span class="btn-text__inner" data-text="Join the Movement">Join the Movement</span></span>
        <svg class="btn-icon" width="18" height="18" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
      <a href="#manifesto" class="btn-ghost">
        <span class="btn-text"><span class="btn-text__inner" data-text="Read Manifesto">Read Manifesto</span></span>
      </a>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="hero__scroll reveal" data-anim="fade" aria-hidden="true">
    <div class="hero__scroll-bar"></div>
    <span class="hero__scroll-label">Scroll</span>
  </div>
</section>

<style lang="scss">
.hero {
  position: relative;
  min-height: 100vh;
  min-height: 100svh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;

  &__shader {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    @media (max-width: 768px) { display: none; }
  }

  &__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }

  &__orb-1 { top: 5%; left: 50%; transform: translateX(-50%); }
  &__orb-2 { bottom: 5%; right: 5%; }

  &__content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: calc(var(--nav-h) + 40px) 0 80px;
  }

  // Tags
  &__tags {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: clamp(32px, 5vh, 56px);
  }
  &__tag {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 600;
    font-size: var(--fs-tag);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--c-grey-1);
  }
  &__tag-sep { color: var(--c-grey-3); font-size: 0.6rem; }

  // Title
  &__title {
    font-size: var(--fs-display);
    line-height: 0.88;
    letter-spacing: -0.05em;
    margin-bottom: clamp(28px, 5vh, 52px);
  }
  &__lime { color: var(--c-lime); }

  // Sub
  &__sub {
    font-size: var(--fs-body);
    color: var(--c-grey-1);
    line-height: 1.75;
    max-width: 460px;
    margin: 0 auto clamp(36px, 5vh, 56px);
  }

  // CTAs
  &__ctas {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  // Scroll indicator (Lando style)
  &__scroll {
    position: absolute;
    bottom: clamp(24px, 4vh, 40px);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    z-index: 2;
    @media (max-width: 768px) { display: none; }
  }
  &__scroll-bar {
    width: 1px;
    height: 56px;
    position: relative;
    overflow: hidden;
    background: var(--c-grey-3);
    &::after {
      content: '';
      position: absolute;
      top: -100%;
      left: 0;
      width: 100%;
      height: 100%;
      background: var(--c-lime);
      animation: scroll-bar 2.4s var(--cubic) infinite;
    }
  }
  &__scroll-label {
    font-family: 'Inter Tight', sans-serif;
    font-weight: 500;
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--c-grey-2);
  }
}

@keyframes scroll-bar {
  0% { top: -100%; }
  50% { top: 0%; }
  100% { top: 100%; }
}
</style>
