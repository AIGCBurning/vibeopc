---
import Nav from '../components/Nav.astro';
import Preloader from '../components/Preloader.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Manifesto from '../components/Manifesto.astro';
import Vision3D from '../components/Vision3D.astro';
import Showcase from '../components/Showcase.astro';
import Pillars from '../components/Pillars.astro';
import Stats from '../components/Stats.astro';
import Marquee2 from '../components/Marquee2.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.scss';
import '../styles/components.scss';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>vibeOPC — Build Your Empire. One Person. AI Powered.</title>
    <meta name="description" content="The home base for AI-powered one-person companies. Tools, community, and everything you need to build your empire solo." />

    <meta property="og:title" content="vibeOPC — Build Your Empire. One Person. AI Powered." />
    <meta property="og:description" content="The home base for AI-era one-person companies." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://vibeopc.com" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900;1,900&family=Inter:wght@400;500&display=swap" rel="stylesheet" />

    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12/dist/gsap.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12/dist/ScrollTrigger.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/lenis@1/dist/lenis.min.js"></script>
    <script is:inline src="https://cdn.jsdelivr.net/npm/three@0.160/build/three.min.js"></script>
  </head>
  <body>
    <Preloader />

    <!-- Film grain -->
    <div class="noise" aria-hidden="true"></div>

    <Nav />
    <main>
      <Hero />
      <Marquee />
      <Manifesto />
      <Vision3D />
      <Showcase />
      <Pillars />
      <Stats />
      <Marquee2 />
      <CTA />
    </main>
    <Footer />

    <script is:inline>gsap.registerPlugin(ScrollTrigger);</script>
    <script is:inline src="/scripts/cursor-reveal.js"></script>
    <script is:inline src="/scripts/hero-shader.js"></script>
    <script is:inline src="/scripts/particles.js"></script>
    <script is:inline src="/scripts/showcase-visuals.js"></script>
    <script is:inline src="/scripts/three-scene.js"></script>
    <script is:inline src="/scripts/animations.js"></script>
  </body>
</html>
